<!DOCTYPE html>
<html lang="pl">

<head>
    <meta charset="UTF-8">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <nav class="nawigacja">
        <a href="/" class="nav-link">Home</a>
        <a href="/catalog" class="nav-link">Catalog</a>
        <% if (typeof isAuthenticated !=='undefined' && isAuthenticated) { %>
            <a href="/cart" class="nav-link">Cart</a>
            <a href="/orders" class="nav-link">Orders</a>
            <% if (typeof user !=='undefined' && user && user.role==='admin' ) { %>
                <a href="/manager" class="nav-link" style="color: #ff6b6b;">Admin Panel</a>
                <% } %>
                    <form action="/logout" method="POST" style="display: inline;">
                        <button type="submit" class="nav-link">Logout</button>
                    </form>
                    <% } else { %>
                        <a href="/login" class="nav-link">Login</a>
                        <a href="/register" class="nav-link">Register</a>
                        <% } %>
    </nav>

    <div class="container">
        <h1>
            <%= title %>
        </h1>

        <% if (!cart || cart.items.length===0) { %>
            <p>Your cart is empty.</p>
            <a href="/catalog" class="btn">Go to Catalog</a>
            <% } else { %>
                <table class="cart-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Unit Price</th>
                            <th>Quantity</th>
                            <th>Total</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% cart.items.forEach(item=> { %>
                            <tr>
                                <td>
                                    <%= item.productName %>
                                </td>
                                <td>
                                    <%= item.unitPrice %> PLN
                                </td>
                                <td>
                                    <div style="display: inline-flex; align-items: center; gap: 8px;">
                                        <form action="/cart/decrease/<%= item.productId %>" method="POST" style="display: inline;">
                                            <button type="submit" class="btn" style="padding: 6px 10px;">-</button>
                                        </form>

                                        <strong><%= item.quantity %></strong>

                                        <form action="/cart/increase/<%= item.productId %>" method="POST" style="display: inline;">
                                            <button type="submit" class="btn" style="padding: 6px 10px;">+</button>
                                        </form>
                                    </div>
                                </td>
                                <td><strong>
                                        <%= item.totalPrice %> PLN
                                    </strong></td>
                                <td>
                                    <form action="/cart/remove/<%= item.productId %>" method="POST"
                                        style="display: inline;">
                                        <button type="submit" class="btn btn-danger">Remove</button>
                                    </form>
                                </td>
                            </tr>
                            <% }); %>
                    </tbody>
                    <tfoot>
                        <tr>
                            <td colspan="3" style="text-align: right;"><strong>Total:</strong></td>
                            <td colspan="2"><strong>
                                    <%= cart.totalValue %> PLN
                                </strong></td>
                        </tr>
                    </tfoot>
                </table>

                <div class="cart-actions">
                    <form action="/cart/clear" method="POST" style="display: inline;">
                        <button type="submit" class="btn btn-secondary">Clear Cart</button>
                    </form>

                    <form action="/cart/checkout" method="POST" style="display: inline;">
                        <button type="submit" class="btn btn-success">Place Order</button>
                    </form>
                </div>

                <br>
                <a href="/catalog" class="btn">Continue Shopping</a>
                <% } %>
    </div>
</body>

</html>