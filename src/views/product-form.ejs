<!DOCTYPE html>
<html lang="pl">

<head>
    <meta charset="UTF-8">
    <title><%= title %></title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <nav class="nawigacja">
        <a href="/" class="nav-link">Home</a>
        <a href="/manager" class="nav-link">Products</a>
        <a href="/manager/orders" class="nav-link">Orders</a>
        <a href="/manager/users" class="nav-link">Users</a>
    </nav>

    <div class="container">
        <h1><%= title %></h1>

        <form action="<%= action %>" method="POST" style="background: white; padding: 20px; border: 1px solid #ddd;">
            
            <div style="margin-bottom: 15px;">
                <label>ID Product:</label><br>
                <input type="text" name="id" value="<%= product ? product.ID : '' %>" 
                       <%= product ? 'readonly' : '' %> required style="width: 100%; padding: 8px;">
            </div>

            <div style="margin-bottom: 15px;">
                <label>Name:</label><br>
                <input type="text" name="name" value="<%= product ? product.name : '' %>" required style="width: 100%; padding: 8px;">
            </div>

            <div style="margin-bottom: 15px;">
                <label>Price (PLN):</label><br>
                <input type="number" name="price" value="<%= product ? product.price : '' %>" required style="width: 100%; padding: 8px;">
            </div>

            <button type="submit" class="btn" style="background-color: green;">Save</button>
        </form>
    </div>
</body>

</html>