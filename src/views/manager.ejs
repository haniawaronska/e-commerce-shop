<!DOCTYPE html>
<html lang="pl">

<head>
    <meta charset="UTF-8">
    <title>
        <%= title %>
    </title>
    <link rel="stylesheet" href="/style.css">
</head>

<body>
    <nav class="nawigacja">
        <a href="/" class="nav-link">Home</a>
        <a href="/manager" class="nav-link">Products</a>
        <a href="/manager/orders" class="nav-link">Orders</a>
        <a href="/manager/users" class="nav-link">Users</a>
        <form action="/logout" method="POST" style="display: inline;">
            <button type="submit" class="nav-link">Logout</button>
        </form>
    </nav>

    <div class="container">
        <h2>
            <%= title %>
        </h2>

        <a href="/manager/add" class="btn" style="background-color: green; margin-bottom: 20px;">+ Add New Product</a>

        <table style="width: 100%; border-collapse: collapse; margin-top: 20px;">
            <thead>
                <tr class="manager-table">
                    <th style="padding: 10px;">ID</th>
                    <th style="padding: 10px;">Name</th>
                    <th style="padding: 10px;">Price</th>
                    <th style="padding: 10px;">Actions</th>
                </tr>
            </thead>
            <tbody>
                <% products.forEach(function(p) { %>
                    <tr style="border-bottom: 1px solid #eee;">
                        <td style="padding: 10px;">
                            <%= p.ID %>
                        </td>
                        <td style="padding: 10px;">
                            <%= p.name %>
                        </td>
                        <td style="padding: 10px;">
                            <%= p.price %> PLN
                        </td>
                        <td style="padding: 10px;">
                            <a href="/manager/edit/<%= p.ID %>" class="btn">Edit</a>
                            <form action="/manager/delete/<%= p.ID %>" method="POST"
                                style="display:inline; margin-left: 5px;">
                                <button type="submit" class="btn delete-btn">Delete
                                </button>
                            </form>
                        </td>
                    </tr>
                    <% }); %>
            </tbody>
        </table>
    </div>
</body>

</html>